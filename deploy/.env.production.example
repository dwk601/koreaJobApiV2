# ─────────────────────────────────────────────────────────────────────────
#  apiV2 — production environment template for Coolify deployment
# ─────────────────────────────────────────────────────────────────────────
#
# This file is a REFERENCE, not something the container reads. Paste each
# key/value into Coolify → Application → Environment, then deploy.
#
# Obtaining the resource URLs (Postgres / Redis / Meilisearch):
#   Coolify UI → Resources → <your resource> → "Connect" / "Connection"
#   tab. Copy the "Internal" value; that host is reachable from this app
#   because both are attached to the same Docker network (see
#   COOLIFY_NETWORK below).
#
# Coolify auto-injects a handful of system variables (COOLIFY_URL,
# COOLIFY_FQDN, COOLIFY_APP_UUID, COOLIFY_DEPLOYMENT_UUID, …). You do
# NOT need to set those here; they are available to all services at
# runtime.
#
# SECRETS: never commit the filled-in version of this file. Store real
# credentials in Coolify's env UI (they're encrypted at rest there) and
# keep this template with placeholders only.
# ─────────────────────────────────────────────────────────────────────────


# ─────── Public URL (Coolify magic variable) ────────────────────────────
#
# SERVICE_FQDN_API_8000 = <coolify-magic>
#
#   Coolify replaces this with a real FQDN + Traefik labels at deploy
#   time, automatically fetching a Let's Encrypt cert. The `_API_8000`
#   suffix must match the compose service name (`api`) and its internal
#   port (`8000`). Leave the value empty in Coolify's UI to get a
#   generated *.sslip.io subdomain, or set it to a custom domain you
#   own (DNS A record → Coolify host IP).
SERVICE_FQDN_API_8000=


# ─────── Coolify network override (only if non-default) ──────────────────
#
# The compose file attaches every service to an external network so it
# can reach the managed Postgres / Redis / Meilisearch resources. On a
# stock Coolify install this network is called `coolify`. Override here
# if `docker network ls` on your server shows something else.
COOLIFY_NETWORK=coolify


# ─────── Meilisearch resource network (REQUIRED) ─────────────────────────
#
# Coolify puts each managed resource on its own private Docker network
# named after the resource's UUID. Postgres and Redis are typically
# ALSO attached to the shared `coolify` network, but **Meilisearch is
# not**, so the app can't resolve the `meilisearch-<uuid>` hostname
# without joining Meilisearch's private network explicitly.
#
# Find the value:
#   Coolify UI → Resources → <your Meilisearch> → Connect (Internal)
#   → the hostname looks like `meilisearch-hlhprexpqq7cva0egwahr7ei`
#   → copy the UUID suffix (`hlhprexpqq7cva0egwahr7ei` in this example).
# Or on the host: `docker network ls` and pick the network whose name
# matches the hostname suffix.
#
# If you've manually attached Meilisearch to the `coolify` network from
# the Meilisearch resource's Network tab, this variable is not needed
# — but in that case also remove `meili_net` from each service's
# `networks:` list in docker-compose.yml.
MEILI_NETWORK=CHANGE_ME


# ─────── App ────────────────────────────────────────────────────────────
APP_NAME=apiV2
DEBUG=false
LOG_LEVEL=INFO


# ─────── Postgres (async SQLAlchemy DSN, asyncpg driver) ───────────────
#
# Format:
#   postgresql+asyncpg://USER:PASSWORD@HOST:5432/DB
#
# HOST is the Coolify-internal hostname from the Postgres resource's
# "Connect" tab (looks like a short service UUID, e.g.
# `i4wgoc0w0s0k840w848s0kcs`). Include the +asyncpg driver; the ETL
# stack owns the schema.
DATABASE_URL=postgresql+asyncpg://CHANGE_ME:CHANGE_ME@CHANGE_ME:5432/job


# ─────── Redis ───────────────────────────────────────────────────────────
#
# Coolify's managed Redis resource exposes an internal hostname on the
# `coolify` network. If your Redis instance requires AUTH, embed it:
#   redis://:PASSWORD@HOST:6379/0
REDIS_URL=redis://CHANGE_ME:6379/0
REDIS_MAX_CONNECTIONS=20
REDIS_SOCKET_TIMEOUT=5
REDIS_SOCKET_CONNECT_TIMEOUT=5


# ─────── Meilisearch ────────────────────────────────────────────────────
#
# MEILI_URL must point at the internal Coolify hostname — **never** the
# public URL (the master key is a privileged admin credential and
# Meilisearch has no TLS of its own).
MEILI_URL=http://CHANGE_ME:7700
MEILI_MASTER_KEY=CHANGE_ME
MEILI_INDEX_NAME=jobs
MEILI_TIMEOUT_MS=5000


# ─────── CORS ───────────────────────────────────────────────────────────
#
# Comma-separated list of allowed origins for the web app. Use the
# PROD frontend origin(s); `*` allows all and disables credentialed
# requests. Example: https://uskoreajob.com,https://www.uskoreajob.com
CORS_ORIGINS=https://CHANGE_ME


# ─────── Rate limiting (production caps) ────────────────────────────────
#
# Caps are per-client-IP per-minute. Tune based on expected traffic.
RATE_LIMIT_ENABLED=true
RATE_LIMIT_LIST_PER_MIN=120
RATE_LIMIT_SUGGEST_PER_MIN=30
RATE_LIMIT_DEFAULT_PER_MIN=60


# ─────── Cache TTLs (seconds) ───────────────────────────────────────────
#
# These are safe to raise if you need to shed more read load off
# Postgres / Meilisearch. Detail lookups cache the longest because
# they're the heaviest per-row query.
CACHE_TTL_LIST=60
CACHE_TTL_FACETS=120
CACHE_TTL_STATS=300
CACHE_TTL_SUGGEST=30
CACHE_TTL_DETAIL=300


# ─────── Sync worker ────────────────────────────────────────────────────
#
# SYNC_BATCH_SIZE      — rows per Meilisearch add_documents batch.
# SYNC_LOCK_TTL        — seconds; also the upper bound for how long a
#                        full reindex is allowed to hold the Redis
#                        advisory lock. Increase if your full reindex
#                        ever exceeds this (watch sync.full.done logs).
# SYNC_DESCRIPTION_MAX_BYTES — truncates the description field pushed
#                        into Meilisearch to keep documents compact.
SYNC_BATCH_SIZE=500
SYNC_LOCK_TTL=3600
SYNC_DESCRIPTION_MAX_BYTES=4096


# ─────── Alembic mode (set by compose; documented here for reference) ──
#
# The compose file hard-codes these — don't set them in Coolify:
#   api        → ALEMBIC_MODE=upgrade   (runs migrations on boot)
#   sync-init  → ALEMBIC_MODE=skip      (never touches schema)
#   sync-cron  → ALEMBIC_MODE=skip      (never touches schema)
