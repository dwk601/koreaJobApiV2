# ─────── App ───────
APP_NAME=apiV2
DEBUG=false
LOG_LEVEL=INFO

# ─────── Postgres (async SQLAlchemy) ───────
# Example for Coolify internal hostname:
# postgresql+asyncpg://dev:PASSWORD@i4wgoc0w0s0k840w848s0kcs:5432/job
DATABASE_URL=postgresql+asyncpg://dev:devpassword@localhost:5432/job

# ─────── Redis ───────
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=10
REDIS_SOCKET_TIMEOUT=5
REDIS_SOCKET_CONNECT_TIMEOUT=5

# ─────── Meilisearch ───────
MEILI_URL=http://localhost:7700
MEILI_MASTER_KEY=masterKey
MEILI_INDEX_NAME=jobs
MEILI_TIMEOUT_MS=5000

# ─────── CORS (comma-separated; * allows all) ───────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ─────── Rate limiting ───────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_LIST_PER_MIN=120
RATE_LIMIT_SUGGEST_PER_MIN=30
RATE_LIMIT_DEFAULT_PER_MIN=60

# ─────── Cache TTLs (seconds) ───────
CACHE_TTL_LIST=60
CACHE_TTL_FACETS=120
CACHE_TTL_STATS=300
CACHE_TTL_SUGGEST=30
CACHE_TTL_DETAIL=300

# ─────── Sync worker ───────
SYNC_BATCH_SIZE=500
SYNC_LOCK_TTL=3600
SYNC_DESCRIPTION_MAX_BYTES=4096
